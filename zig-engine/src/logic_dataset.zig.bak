// ќ©-иРље∞ШAGI йАїиЊСиЃ≠зїГжХ∞жНЃйЫЖ v4.1.2
//
// дЄ•ж†ЉеѓєеЇФзЩљзЪЃдє¶v2.0пЉЪ
// - зђђ2зЂ†пЉЪCDLж†Љenriched 2-иМГзХі
// - зђђ7зЂ†пЉЪCL-SCT+иЃ≠зїГиМГеЉП
// - зђђ8зЂ†пЉЪеЫЫе±ВжХ∞жНЃйЫЖжЮґжЮД
//
// иЃЊиЃ°еУ≤е≠¶пЉИж†ЄењГпЉЪќФдЄЇеФѓдЄАеОЯиѓ≠пЉЙпЉЪ
// йАїиЊСињРзЃЧдЄНжШѓ"жЦ∞еКЯиГљ"пЉМиАМжШѓж†ЉињРзЃЧеЬ®{0,1}еЄГе∞ФеЯЯдЄКзЪДзЙєдЊЛгАВ
// з≥їзїЯеЈ≤зїПеЕЈе§ЗжЙАжЬЙж†ЉињРзЃЧиГљеКЫпЉИlatticeJoin/latticeMeet/deltaпЉЙпЉМ
// еП™йЬАи¶БиЃ≠зїГжХ∞жНЃиЃ©еЃГ"еПСзО∞" PвИІQ = lattice_meet(P,Q) ињЩдЄ™жШ†е∞ДгАВ
//
// дЄНеЉХеЕ•дїїдљХжЦ∞з±їеЮЛпЉМеЕ®йГ®дљњзФ®еЈ≤жЬЙ TaskTypeпЉЪ
// - LatticeOperation    вЖТ AND(meet), OR(join), вЖТ(joinзїДеРИ), вЖФ(meetзїДеРИ), вКХ(joinзїДеРИ)
// - BasicDeltaOperation вЖТ NOT(delta(1, P))
//
// з¶БзФ®з±їеЮЛпЉИзФ®жИЈи¶Бж±ВдїЕдљњзФ®дї•дЄКдЄ§зІНпЉЙпЉЪ
// - EquivalenceTransformпЉИвЖФзФ®latticeMeetзїДеРИеЃЮзО∞пЉЙ
// - MorphismReasoningпЉИжО®зРЖиІДеИЩзФ®LatticeOperationи°®иЊЊпЉЙ
// - SelfValidationпЉИиЗ™ж†°й™МзФ®LatticeOperationи°®иЊЊпЉЙ
//
// иДСеЖЕжЉФзЃЧпЉИжЧ†иНЙз®њзЇЄпЉЙпЉЪ
// P AND Q = lattice_meet(P, Q)      вЖР LatticeOperation
// P OR Q  = lattice_join(P, Q)      вЖР LatticeOperation
// NOT P   = delta(1, P)             вЖР BasicDeltaOperation
// P вЖТ Q   = join(delta(1,P), Q)     вЖР LatticeOperationпЉИе§Це±ВжШѓjoinпЉЙ
// P вЖФ Q   = meet(PвЖТQ, QвЖТP)         вЖР LatticeOperationпЉИе§Це±ВжШѓmeetпЉЙ
// P вКХ Q   = join(meet(P,¬ђQ), meet(¬ђP,Q)) вЖР LatticeOperationпЉИе§Це±ВжШѓjoinпЉЙ
//
// зЇѓќФеЃЮзО∞пЉИдЄНжЦ∞еҐЮињРзЃЧзђ¶пЉЙпЉЪ
// жЙАжЬЙ expected еАЉйАЪињЗзО∞жЬЙ engine жЦєж≥ХзЫіжО•еЖЕиБФжО®еѓЉпЉМжЧ†иЊЕеК©еЗљжХ∞пЉЪ
// - latticeJoin(a_id, b_id) ињФеЫЮ LatticeOperationError!f64
// - latticeMeet(a_id, b_id) ињФеЫЮ LatticeOperationError!f64
// - delta(x_id, y_id)       ињФеЫЮ f64пЉИжЧ†errorпЉЙ
//
// йУЊеЉПи∞ГзФ®пЉЪlatticeJoin/latticeMeet ињФеЫЮ f64пЉМдЉ†еЕ•дЄЛдЄАдЄ™ж†ЉињРзЃЧеЙН
// йЬАи¶БзФ® getOrCreateNumber(@intFromFloat(val)) иљђеЫЮ u64 еѓєи±°ID

const std = @import("std");
const tt = @import("trainer_types.zig");
const DeltaEngine = @import("delta_engine.zig").DeltaEngine;
const eds = @import("endogenous_dataset.zig");

// ============================================================
// йАїиЊСиЃ≠зїГжХ∞жНЃйЫЖпЉИйБµеЊ™EndogenousDatasetеЫЫе±ВжЮґжЮДпЉЙ
// ============================================================

/// йАїиЊСиЃ≠зїГжХ∞жНЃйЫЖзЃ°зРЖеЩ®
///
/// иЃЊиЃ°еЃЪдєЙпЉЪ
///   йБµеЊ™зЩљзЪЃдє¶зђђ8зЂ†еЫЫе±ВжХ∞жНЃйЫЖжЮґжЮДпЉМеЕ®йГ®дљњзФ®еЈ≤жЬЙ TaskTypeпЉЪ
///   - LatticeOperationпЉЪANDпЉИmeetпЉЙгАБORпЉИjoinпЉЙгАБвЖТпЉИjoin+deltaзїДеРИпЉЙ
///   - BasicDeltaOperationпЉЪNOTпЉИdeltaпЉЙ
///
/// ж†ЄењГеУ≤е≠¶пЉЪ
///   жЙАжЬЙ expected еАЉйАЪињЗќФ/ж†ЉињРзЃЧжО®еѓЉпЉМдЄ•з¶Бз°ђзЉЦз†БзЬЯеАЉи°®гАВ
///   з≥їзїЯдЄНйЬАи¶БзЯ•йБУ"ињЩжШѓйАїиЊС"вАФвАФеЃГеП™йЬАи¶БйАЪињЗќФеОЛеКЫе≠¶дЉЪ
///   lattice_meet(1,0)=0 ињЩдЄ™жШ†е∞ДпЉМзДґеРОиЗ™зДґе∞±иГљеБЪ AND ињРзЃЧгАВ
pub const LogicDataset = struct {
    // еЫЫе±ВжХ∞жНЃйЫЖпЉИдљњзФ®дЄОжХ∞е≠¶ињРзЃЧзЫЄеРМзЪДжХ∞жНЃзїУжЮДпЉЙ
    axiom_benchmarks: std.ArrayList(eds.DatasetSample),
    bootstrap_generated: std.ArrayList(eds.DatasetSample),
    auto_expanded: std.ArrayList(eds.DatasetSample),
    adversarial_boundary: std.ArrayList(eds.DatasetSample),
    allocator: std.mem.Allocator,

    pub fn init(allocator: std.mem.Allocator) LogicDataset {
        return .{
            .axiom_benchmarks = std.ArrayList(eds.DatasetSample).empty,
            .bootstrap_generated = std.ArrayList(eds.DatasetSample).empty,
            .auto_expanded = std.ArrayList(eds.DatasetSample).empty,
            .adversarial_boundary = std.ArrayList(eds.DatasetSample).empty,
            .allocator = allocator,
        };
    }

    pub fn deinit(self: *LogicDataset) void {
        self.axiom_benchmarks.deinit(self.allocator);
        self.bootstrap_generated.deinit(self.allocator);
        self.auto_expanded.deinit(self.allocator);
        self.adversarial_boundary.deinit(self.allocator);
    }

    /// иОЈеПЦжМЗеЃЪз±їеЮЛзЪДж†ЈжЬђ
    pub fn getSample(self: *const LogicDataset, sample_type: eds.SampleType) ?eds.DatasetSample {
        const list = switch (sample_type) {
            .AxiomBenchmark => self.axiom_benchmarks.items,
            .BootstrapGenerated => self.bootstrap_generated.items,
            .AutoExpanded => self.auto_expanded.items,
            .AdversarialBoundary => self.adversarial_boundary.items,
        };
        if (list.len == 0) return null;
        return list[0];
    }

    /// иОЈеПЦжМЗеЃЪз±їеЮЛж†ЈжЬђжХ∞йЗП
    pub fn sampleCount(self: *const LogicDataset, sample_type: eds.SampleType) usize {
        return switch (sample_type) {
            .AxiomBenchmark => self.axiom_benchmarks.items.len,
            .BootstrapGenerated => self.bootstrap_generated.items.len,
            .AutoExpanded => self.auto_expanded.items.len,
            .AdversarialBoundary => self.adversarial_boundary.items.len,
        };
    }

    /// иОЈеПЦжАїж†ЈжЬђжХ∞йЗП
    pub fn totalCount(self: *const LogicDataset) usize {
        return self.axiom_benchmarks.items.len +
            self.bootstrap_generated.items.len +
            self.auto_expanded.items.len +
            self.adversarial_boundary.items.len;
    }

    /// зФЯжИРзђђдЄАе±ВпЉЪеЕђзРЖеЯЇеЗЖйЫЖпЉИзЬЯеАЉи°®пЉМйАЪињЗќФ/ж†ЉињРзЃЧжО®еѓЉпЉЙ
    ///
    /// жЙАжЬЙ P,Q вИИ {0,1} зЪД6зІНйАїиЊСињРзЃЧзЬЯеАЉи°®пЉМжѓПзІН4и°МпЉИ4зІНзїДеРИпЉЙгАВ
    /// expected еЕ®йГ®йАЪињЗ engine зЪДзО∞жЬЙж†Љ/ќФињРзЃЧеЖЕиБФиЃ°зЃЧпЉМдЄ•з¶Бз°ђзЉЦз†БгАВ
    ///
    /// з±їеЮЛеИЖеЄГпЉЪ
    ///   - LatticeOperationпЉЪAND, OR, вЖТ, вЖФ, вКХпЉИ5зІН √Ч 4зїДеРИ = 20жЭ°ж≠£ж†ЈжЬђпЉЙ
    ///   - BasicDeltaOperationпЉЪNOTпЉИ1зІН √Ч 2зїДеРИ = 2жЭ°ж≠£ж†ЈжЬђпЉЙ
    pub fn generateAxiomBenchmarks(self: *LogicDataset, engine: *DeltaEngine) !void {
        self.axiom_benchmarks.clearRetainingCapacity();

        const booleans = [_]u64{ 0, 1 };
        for (booleans) |p| {
            for (booleans) |q| {
                const p_id = try engine.getOrCreateNumber(p);
                const q_id = try engine.getOrCreateNumber(q);

                // AND: P вИІ Q = lattice_meet(P, Q) вЖТ LatticeOperation
                {
                    const result = try engine.latticeMeet(p_id, q_id);
                    const expected: i64 = @intFromFloat(result);
                    // ж≠£ж†ЈжЬђ
                    try self.axiom_benchmarks.append(self.allocator, .{
                        .sample_type = .AxiomBenchmark,
                        .level = 1,
                        .complexity = .Level_3,
                        .param1 = @intCast(p),
                        .param2 = @intCast(q),
                        .expected = expected,
                        .is_positive = true,
                        .equivalent_pair_id = null,
                    });
                    // иіЯж†ЈжЬђпЉЪеПЦеПНзЪДж≠£з°ЃзїУжЮЬ
                    const wrong = if (expected == 0) @as(i64, 1) else @as(i64, 0);
                    try self.axiom_benchmarks.append(self.allocator, .{
                        .sample_type = .AxiomBenchmark,
                        .level = 1,
                        .complexity = .Level_3,
                        .param1 = @intCast(p),
                        .param2 = @intCast(q),
                        .expected = wrong,
                        .is_positive = false,
                        .equivalent_pair_id = null,
                    });
                }

                // OR: P вИ® Q = lattice_join(P, Q) вЖТ LatticeOperation
                {
                    const result = try engine.latticeJoin(p_id, q_id);
                    const expected: i64 = @intFromFloat(result);
                    try self.axiom_benchmarks.append(self.allocator, .{
                        .sample_type = .AxiomBenchmark,
                        .level = 1,
                        .complexity = .Level_3,
                        .param1 = @intCast(p),
                        .param2 = @intCast(q),
                        .expected = expected,
                        .is_positive = true,
                        .equivalent_pair_id = null,
                    });
                }

                // вЖТ: PвЖТQ = join(delta(1,P), Q) вЖТ LatticeOperation
                {
                    const not_p_val = engine.deltaExpr(engine.one_id, p_id);
                    const not_p_id = try engine.getOrCreateNumber(@intFromFloat(not_p_val));
                    const result = try engine.latticeJoin(not_p_id, q_id);
                    const expected: i64 = @intFromFloat(result);
                    try self.axiom_benchmarks.append(self.allocator, .{
                        .sample_type = .AxiomBenchmark,
                        .level = 1,
                        .complexity = .Level_3,
                        .param1 = @intCast(p),
                        .param2 = @intCast(q),
                        .expected = expected,
                        .is_positive = true,
                        .equivalent_pair_id = null,
                    });
                }

                // вЖФ: PвЖФQ = meet(PвЖТQ, QвЖТP) вЖТ LatticeOperation
                {
                    const not_p_val = engine.deltaExpr(engine.one_id, p_id);
                    const not_p_id = try engine.getOrCreateNumber(@intFromFloat(not_p_val));
                    const p_to_q = try engine.latticeJoin(not_p_id, q_id);
                    const p_to_q_id = try engine.getOrCreateNumber(@intFromFloat(p_to_q));

                    const not_q_val = engine.deltaExpr(engine.one_id, q_id);
                    const not_q_id = try engine.getOrCreateNumber(@intFromFloat(not_q_val));
                    const q_to_p = try engine.latticeJoin(not_q_id, p_id);
                    const q_to_p_id = try engine.getOrCreateNumber(@intFromFloat(q_to_p));

                    const result = try engine.latticeMeet(p_to_q_id, q_to_p_id);
                    const expected: i64 = @intFromFloat(result);
                    try self.axiom_benchmarks.append(self.allocator, .{
                        .sample_type = .AxiomBenchmark,
                        .level = 1,
                        .complexity = .Level_3,
                        .param1 = @intCast(p),
                        .param2 = @intCast(q),
                        .expected = expected,
                        .is_positive = true,
                        .equivalent_pair_id = null,
                    });
                }

                // вКХ: PвКХQ = join(meet(P,¬ђQ), meet(¬ђP,Q)) вЖТ LatticeOperation
                {
                    const not_p_val = engine.deltaExpr(engine.one_id, p_id);
                    const not_p_id = try engine.getOrCreateNumber(@intFromFloat(not_p_val));
                    const not_q_val = engine.deltaExpr(engine.one_id, q_id);
                    const not_q_id = try engine.getOrCreateNumber(@intFromFloat(not_q_val));

                    const p_and_not_q = try engine.latticeMeet(p_id, not_q_id);
                    const p_and_not_q_id = try engine.getOrCreateNumber(@intFromFloat(p_and_not_q));
                    const not_p_and_q = try engine.latticeMeet(not_p_id, q_id);
                    const not_p_and_q_id = try engine.getOrCreateNumber(@intFromFloat(not_p_and_q));

                    const result = try engine.latticeJoin(p_and_not_q_id, not_p_and_q_id);
                    const expected: i64 = @intFromFloat(result);
                    try self.axiom_benchmarks.append(self.allocator, .{
                        .sample_type = .AxiomBenchmark,
                        .level = 1,
                        .complexity = .Level_3,
                        .param1 = @intCast(p),
                        .param2 = @intCast(q),
                        .expected = expected,
                        .is_positive = true,
                        .equivalent_pair_id = null,
                    });
                }
            }
        }

        // NOT: ¬ђP = delta(1, P) вЖТ BasicDeltaOperationпЉИдЄАеЕГињРзЃЧпЉМеНХзЛђе§ДзРЖпЉЙ
        for (booleans) |p| {
            const p_id = try engine.getOrCreateNumber(p);
            const result: f64 = engine.deltaExpr(engine.one_id, p_id);
            const expected: i64 = @intFromFloat(result);
            try self.axiom_benchmarks.append(self.allocator, .{
                .sample_type = .AxiomBenchmark,
                .level = 1,
                .complexity = .Level_1,
                .param1 = @intCast(p),
                .param2 = 0,
                .expected = expected,
                .is_positive = true,
                .equivalent_pair_id = null,
            });
        }
    }

    /// зФЯжИРзђђдЇМе±ВпЉЪиЗ™дЄЊзФЯжИРйЫЖпЉИдЄЙе±ВеµМе•ЧйАїиЊСи°®иЊЊеЉПпЉЙ
    ///
    /// еЕ®йГ®дљњзФ® LatticeOperation з±їеЮЛпЉМеЫ†дЄЇжЙАжЬЙе§НеРИи°®иЊЊеЉПзЪД
    /// жЬАе§Це±ВињРзЃЧйГљжШѓlatticeJoinжИЦlatticeMeetгАВ
    /// P,Q,R вИИ {0,1} еЕ±8зІНзїДеРИпЉМжѓПзІН3дЄ™и°®иЊЊеЉП = 24жЭ°ж≠£ж†ЈжЬђгАВ
    pub fn generateBootstrapSamples(self: *LogicDataset, engine: *DeltaEngine) !void {
        self.bootstrap_generated.clearRetainingCapacity();

        const booleans = [_]u64{ 0, 1 };

        for (booleans) |p| {
            for (booleans) |q| {
                for (booleans) |r| {
                    const p_id = try engine.getOrCreateNumber(p);
                    const q_id = try engine.getOrCreateNumber(q);
                    const r_id = try engine.getOrCreateNumber(r);

                    // зЉЦз†Б3жѓФзЙєдЄЇparam1: P*4 + Q*2 + R
                    const encoded = @as(i64, @intCast(p * 4 + q * 2 + r));

                    // (PвИІQ)вЖТR = join(delta(1, meet(P,Q)), R) вЖТ LatticeOperation
                    {
                        const and_pq = try engine.latticeMeet(p_id, q_id);
                        const and_pq_id = try engine.getOrCreateNumber(@intFromFloat(and_pq));
                        const not_and_val = engine.deltaExpr(engine.one_id, and_pq_id);
                        const not_and_id = try engine.getOrCreateNumber(@intFromFloat(not_and_val));
                        const result = try engine.latticeJoin(not_and_id, r_id);
                        const expected: i64 = @intFromFloat(result);
                        try self.bootstrap_generated.append(self.allocator, .{
                            .sample_type = .BootstrapGenerated,
                            .level = 2,
                            .complexity = .Level_3,
                            .param1 = encoded,
                            .param2 = 0,
                            .expected = expected,
                            .is_positive = true,
                            .equivalent_pair_id = null,
                        });
                    }

                    // PвИ®(QвИІR) = join(P, meet(Q,R)) вЖТ LatticeOperation
                    {
                        const and_qr = try engine.latticeMeet(q_id, r_id);
                        const and_qr_id = try engine.getOrCreateNumber(@intFromFloat(and_qr));
                        const result = try engine.latticeJoin(p_id, and_qr_id);
                        const expected: i64 = @intFromFloat(result);
                        try self.bootstrap_generated.append(self.allocator, .{
                            .sample_type = .BootstrapGenerated,
                            .level = 2,
                            .complexity = .Level_3,
                            .param1 = encoded,
                            .param2 = 1,
                            .expected = expected,
                            .is_positive = true,
                            .equivalent_pair_id = null,
                        });
                    }

                    // (PвЖТQ)вИІ(QвЖТR) = meet(join(delta(1,P),Q), join(delta(1,Q),R)) вЖТ LatticeOperation
                    {
                        const not_p_val = engine.deltaExpr(engine.one_id, p_id);
                        const not_p_id = try engine.getOrCreateNumber(@intFromFloat(not_p_val));
                        const p_to_q = try engine.latticeJoin(not_p_id, q_id);
                        const p_to_q_id = try engine.getOrCreateNumber(@intFromFloat(p_to_q));

                        const not_q_val = engine.deltaExpr(engine.one_id, q_id);
                        const not_q_id = try engine.getOrCreateNumber(@intFromFloat(not_q_val));
                        const q_to_r = try engine.latticeJoin(not_q_id, r_id);
                        const q_to_r_id = try engine.getOrCreateNumber(@intFromFloat(q_to_r));

                        const result = try engine.latticeMeet(p_to_q_id, q_to_r_id);
                        const expected: i64 = @intFromFloat(result);
                        try self.bootstrap_generated.append(self.allocator, .{
                            .sample_type = .BootstrapGenerated,
                            .level = 2,
                            .complexity = .Level_3,
                            .param1 = encoded,
                            .param2 = 2,
                            .expected = expected,
                            .is_positive = true,
                            .equivalent_pair_id = null,
                        });
                    }
                }
            }
        }
    }

    /// зФЯжИРзђђдЄЙе±ВпЉЪиЗ™дЄїжЙ©еЉ†йЫЖпЉИжО®зРЖиІДеИЩй™МиѓБгАБз≠ЙдїЈеЃЪеЊЛпЉЙ
    ///
    /// й™МиѓБйАїиЊСеЃЪеЊЛеЬ®жЙАжЬЙ P,Q вИИ {0,1} дЄКжБТжИРзЂЛгАВ
    /// еЕ®йГ®дљњзФ® LatticeOperation з±їеЮЛгАВ
    ///
    /// й™МиѓБеЃЪеЊЛпЉЪ
    /// - еБЗи®АжО®зРЖпЉИModus PonensпЉЙпЉЪ((PвЖТQ)вИІP) вЖТ Q
    /// - жЛТеПЦеЉПпЉИModus TollensпЉЙпЉЪ((PвЖТQ)вИІ¬ђQ) вЖТ ¬ђP
    /// - DeMorganеЊЛ1пЉЪ¬ђ(PвИІQ) вЖФ (¬ђPвИ®¬ђQ)
    /// - DeMorganеЊЛ2пЉЪ¬ђ(PвИ®Q) вЖФ (¬ђPвИІ¬ђQ)
    pub fn generateAutoExpandedSamples(self: *LogicDataset, engine: *DeltaEngine) !void {
        self.auto_expanded.clearRetainingCapacity();

        const booleans = [_]u64{ 0, 1 };

        for (booleans) |p| {
            for (booleans) |q| {
                const p_id = try engine.getOrCreateNumber(p);
                const q_id = try engine.getOrCreateNumber(q);

                // еБЗи®АжО®зРЖпЉЪ((PвЖТQ)вИІP) вЖТ Q вЖТ LatticeOperationпЉИеЇФжБТдЄЇзЬЯпЉЙ
                {
                    // PвЖТQ = join(delta(1,P), Q)
                    const not_p_val = engine.deltaExpr(engine.one_id, p_id);
                    const not_p_id = try engine.getOrCreateNumber(@intFromFloat(not_p_val));
                    const p_implies_q = try engine.latticeJoin(not_p_id, q_id);
                    const p_implies_q_id = try engine.getOrCreateNumber(@intFromFloat(p_implies_q));

                    // (PвЖТQ)вИІP
                    const premise = try engine.latticeMeet(p_implies_q_id, p_id);
                    const premise_id = try engine.getOrCreateNumber(@intFromFloat(premise));

                    // ((PвЖТQ)вИІP) вЖТ Q = join(delta(1, premise), Q)
                    const not_premise_val = engine.deltaExpr(engine.one_id, premise_id);
                    const not_premise_id = try engine.getOrCreateNumber(@intFromFloat(not_premise_val));
                    const result = try engine.latticeJoin(not_premise_id, q_id);
                    const expected: i64 = @intFromFloat(result);
                    try self.auto_expanded.append(self.allocator, .{
                        .sample_type = .AutoExpanded,
                        .level = 3,
                        .complexity = .Level_3,
                        .param1 = @intCast(p),
                        .param2 = @intCast(q),
                        .expected = expected,
                        .is_positive = true,
                        .equivalent_pair_id = null,
                    });
                }

                // жЛТеПЦеЉПпЉЪ((PвЖТQ)вИІ¬ђQ) вЖТ ¬ђP вЖТ LatticeOperationпЉИеЇФжБТдЄЇзЬЯпЉЙ
                {
                    // PвЖТQ = join(delta(1,P), Q)
                    const not_p_val = engine.deltaExpr(engine.one_id, p_id);
                    const not_p_id = try engine.getOrCreateNumber(@intFromFloat(not_p_val));
                    const p_implies_q = try engine.latticeJoin(not_p_id, q_id);
                    const p_implies_q_id = try engine.getOrCreateNumber(@intFromFloat(p_implies_q));

                    // ¬ђQ = delta(1, Q)
                    const not_q_val = engine.deltaExpr(engine.one_id, q_id);
                    const not_q_id = try engine.getOrCreateNumber(@intFromFloat(not_q_val));

                    // (PвЖТQ)вИІ¬ђQ
                    const premise = try engine.latticeMeet(p_implies_q_id, not_q_id);
                    const premise_id = try engine.getOrCreateNumber(@intFromFloat(premise));

                    // ((PвЖТQ)вИІ¬ђQ) вЖТ ¬ђP = join(delta(1, premise), not(P))
                    const not_premise_val = engine.deltaExpr(engine.one_id, premise_id);
                    const not_premise_id = try engine.getOrCreateNumber(@intFromFloat(not_premise_val));
                    const result = try engine.latticeJoin(not_premise_id, not_p_id);
                    const expected: i64 = @intFromFloat(result);
                    try self.auto_expanded.append(self.allocator, .{
                        .sample_type = .AutoExpanded,
                        .level = 3,
                        .complexity = .Level_3,
                        .param1 = @intCast(p),
                        .param2 = @intCast(q),
                        .expected = expected,
                        .is_positive = true,
                        .equivalent_pair_id = null,
                    });
                }

                // DeMorganеЊЛ1пЉЪ¬ђ(PвИІQ) вЖФ (¬ђPвИ®¬ђQ) вЖТ LatticeOperationпЉИеЇФжБТдЄЇзЬЯпЉЙ
                {
                    // еЈ¶ = delta(1, meet(P,Q))
                    const meet_pq = try engine.latticeMeet(p_id, q_id);
                    const meet_pq_id = try engine.getOrCreateNumber(@intFromFloat(meet_pq));
                    const left_val = engine.deltaExpr(engine.one_id, meet_pq_id);
                    const left_id = try engine.getOrCreateNumber(@intFromFloat(left_val));

                    // еП≥ = join(delta(1,P), delta(1,Q))
                    const not_p_val2 = engine.deltaExpr(engine.one_id, p_id);
                    const not_p_id2 = try engine.getOrCreateNumber(@intFromFloat(not_p_val2));
                    const not_q_val2 = engine.deltaExpr(engine.one_id, q_id);
                    const not_q_id2 = try engine.getOrCreateNumber(@intFromFloat(not_q_val2));
                    const right_val = try engine.latticeJoin(not_p_id2, not_q_id2);
                    const right_id = try engine.getOrCreateNumber(@intFromFloat(right_val));

                    // me et(leftвЖТright, rightвЖТleft)
                    const not_left_val = engine.deltaExpr(engine.one_id, left_id);
                    const not_left_id = try engine.getOrCreateNumber(@intFromFloat(not_left_val));
                    const l_to_r = try engine.latticeJoin(not_left_id, right_id);
                    const l_to_r_id = try engine.getOrCreateNumber(@intFromFloat(l_to_r));

                    const not_right_val = engine.deltaExpr(engine.one_id, right_id);
                    const not_right_id = try engine.getOrCreateNumber(@intFromFloat(not_right_val));
                    const r_to_l = try engine.latticeJoin(not_right_id, left_id);
                    const r_to_l_id = try engine.getOrCreateNumber(@intFromFloat(r_to_l));

                    const result = try engine.latticeMeet(l_to_r_id, r_to_l_id);
                    const expected: i64 = @intFromFloat(result);
                    try self.auto_expanded.append(self.allocator, .{
                        .sample_type = .AutoExpanded,
                        .level = 3,
                        .complexity = .Level_3,
                        .param1 = @intCast(p * 2 + q),
                        .param2 = 0,
                        .expected = expected,
                        .is_positive = true,
                        .equivalent_pair_id = null,
                    });
                }

                // DeMorganеЊЛ2пЉЪ¬ђ(PвИ®Q) вЖФ (¬ђPвИІ¬ђQ) вЖТ LatticeOperationпЉИеЇФжБТдЄЇзЬЯпЉЙ
                {
                    // еЈ¶ = delta(1, join(P,Q))
                    const join_pq = try engine.latticeJoin(p_id, q_id);
                    const join_pq_id = try engine.getOrCreateNumber(@intFromFloat(join_pq));
                    const left_val = engine.deltaExpr(engine.one_id, join_pq_id);
                    const left_id = try engine.getOrCreateNumber(@intFromFloat(left_val));

                    // еП≥ = meet(delta(1,P), delta(1,Q))
                    const not_p_val3 = engine.deltaExpr(engine.one_id, p_id);
                    const not_p_id3 = try engine.getOrCreateNumber(@intFromFloat(not_p_val3));
                    const not_q_val3 = engine.deltaExpr(engine.one_id, q_id);
                    const not_q_id3 = try engine.getOrCreateNumber(@intFromFloat(not_q_val3));
                    const right_val = try engine.latticeMeet(not_p_id3, not_q_id3);
                    const right_id = try engine.getOrCreateNumber(@intFromFloat(right_val));

                    // meet(leftвЖТright, rightвЖТleft)
                    const not_left_val = engine.deltaExpr(engine.one_id, left_id);
                    const not_left_id2 = try engine.getOrCreateNumber(@intFromFloat(not_left_val));
                    const l_to_r = try engine.latticeJoin(not_left_id2, right_id);
                    const l_to_r_id2 = try engine.getOrCreateNumber(@intFromFloat(l_to_r));

                    const not_right_val = engine.deltaExpr(engine.one_id, right_id);
                    const not_right_id2 = try engine.getOrCreateNumber(@intFromFloat(not_right_val));
                    const r_to_l = try engine.latticeJoin(not_right_id2, left_id);
                    const r_to_l_id2 = try engine.getOrCreateNumber(@intFromFloat(r_to_l));

                    const result = try engine.latticeMeet(l_to_r_id2, r_to_l_id2);
                    const expected: i64 = @intFromFloat(result);
                    try self.auto_expanded.append(self.allocator, .{
                        .sample_type = .AutoExpanded,
                        .level = 3,
                        .complexity = .Level_3,
                        .param1 = @intCast(p * 2 + q),
                        .param2 = 1,
                        .expected = expected,
                        .is_positive = true,
                        .equivalent_pair_id = null,
                    });
                }
            }
        }
    }

    /// зФЯжИРзђђеЫЫе±ВпЉЪеѓєжКЧиЊєзХМйЫЖпЉИжВЦиЃЇгАБиЗ™жМЗгАБж≠ІдєЙпЉЙ
    ///
    /// еЕ®йГ®дљњзФ® LatticeOperation жИЦ BasicDeltaOperation з±їеЮЛгАВ
    /// жµЛиѓХз≥їзїЯеЬ®жЮБйЩРиЊєзХМcaseдЄЛзЪДжО®зРЖиГљеКЫгАВ
    pub fn generateAdversarialSamples(self: *LogicDataset, engine: *DeltaEngine) !void {
        self.adversarial_boundary.clearRetainingCapacity();

        // 1. жВЦиЃЇпЉЪPвЖФ¬ђPпЉИиЗ™зЫЄзЯЫзЫЊзЪДеСљйҐШпЉЙвЖТ LatticeOperation
        //    P=0жЧґпЉЪ¬ђP=1, PвЖТ¬ђP=1, ¬ђPвЖТP=0, жХідљУ=0пЉИеБЗпЉЙ
        //    P=1жЧґпЉЪ¬ђP=0, PвЖТ¬ђP=0, ¬ђPвЖТP=1, жХідљУ=0пЉИеБЗпЉЙ
        {
            const p_id = try engine.getOrCreateNumber(0);
            const not_p_val = engine.deltaExpr(engine.one_id, p_id);
            const not_p_id = try engine.getOrCreateNumber(@intFromFloat(not_p_val));

            // PвЖТ¬ђP = join(delta(1,P), ¬ђP)
            const not_p_val2 = engine.deltaExpr(engine.one_id, p_id);
            const not_p_id2 = try engine.getOrCreateNumber(@intFromFloat(not_p_val2));
            const p_to_not_p = try engine.latticeJoin(not_p_id2, not_p_id);
            const p_to_not_p_id = try engine.getOrCreateNumber(@intFromFloat(p_to_not_p));

            // ¬ђPвЖТP = join(delta(1,¬ђP), P)
            const not_not_p_val = engine.deltaExpr(engine.one_id, not_p_id);
            const not_not_p_id = try engine.getOrCreateNumber(@intFromFloat(not_not_p_val));
            const not_p_to_p = try engine.latticeJoin(not_not_p_id, p_id);
            const not_p_to_p_id = try engine.getOrCreateNumber(@intFromFloat(not_p_to_p));

            // PвЖФ¬ђP = meet(PвЖТ¬ђP, ¬ђPвЖТP)
            const result = try engine.latticeMeet(p_to_not_p_id, not_p_to_p_id);
            const expected: i64 = @intFromFloat(result);
            try self.adversarial_boundary.append(self.allocator, .{
                .sample_type = .AdversarialBoundary,
                .level = 3,
                .complexity = .Level_3,
                .param1 = 0,
                .param2 = 0,
                .expected = expected,
                .is_positive = true,
                .equivalent_pair_id = null,
            });
        }

        // 2. ж≠ІдєЙй™МиѓБпЉЪ(PвИІQ)вИ®R vs PвИІ(QвИ®R) вЖТ LatticeOperation
        {
            const p_id = try engine.getOrCreateNumber(1);
            const q_id = try engine.getOrCreateNumber(0);
            const r_id = try engine.getOrCreateNumber(1);

            // (PвИІQ)вИ®R = join(meet(P,Q), R)
            const meet_pq = try engine.latticeMeet(p_id, q_id);
            const meet_pq_id = try engine.getOrCreateNumber(@intFromFloat(meet_pq));
            const left = try engine.latticeJoin(meet_pq_id, r_id);
            const left_id = try engine.getOrCreateNumber(@intFromFloat(left));

            // PвИІ(QвИ®R) = meet(P, join(Q,R))
            const join_qr = try engine.latticeJoin(q_id, r_id);
            const join_qr_id = try engine.getOrCreateNumber(@intFromFloat(join_qr));
            const right = try engine.latticeMeet(p_id, join_qr_id);
            const right_id = try engine.getOrCreateNumber(@intFromFloat(right));

            // й™МиѓБз≠ЙдїЈпЉЪmeet(leftвЖТright, rightвЖТleft)
            const not_left_val = engine.deltaExpr(engine.one_id, left_id);
            const not_left_id = try engine.getOrCreateNumber(@intFromFloat(not_left_val));
            const l_to_r = try engine.latticeJoin(not_left_id, right_id);
            const l_to_r_id = try engine.getOrCreateNumber(@intFromFloat(l_to_r));

            const not_right_val = engine.deltaExpr(engine.one_id, right_id);
            const not_right_id = try engine.getOrCreateNumber(@intFromFloat(not_right_val));
            const r_to_l = try engine.latticeJoin(not_right_id, left_id);
            const r_to_l_id = try engine.getOrCreateNumber(@intFromFloat(r_to_l));

            const result = try engine.latticeMeet(l_to_r_id, r_to_l_id);
            const expected: i64 = @intFromFloat(result);
            try self.adversarial_boundary.append(self.allocator, .{
                .sample_type = .AdversarialBoundary,
                .level = 3,
                .complexity = .Level_3,
                .param1 = 1,
                .param2 = 0,
                .expected = expected,
                .is_positive = true,
                .equivalent_pair_id = null,
            });
        }

        // 3. жОТдЄ≠еЊЛпЉЪPвИ®¬ђP жБТдЄЇзЬЯ вЖТ LatticeOperation
        {
            const booleans = [_]u64{ 0, 1 };
            for (booleans) |p| {
                const p_id = try engine.getOrCreateNumber(p);
                const not_p_val = engine.deltaExpr(engine.one_id, p_id);
                const not_p_id = try engine.getOrCreateNumber(@intFromFloat(not_p_val));
                const result = try engine.latticeJoin(p_id, not_p_id);
                const expected: i64 = @intFromFloat(result);
                try self.adversarial_boundary.append(self.allocator, .{
                    .sample_type = .AdversarialBoundary,
                    .level = 3,
                    .complexity = .Level_3,
                    .param1 = @intCast(p),
                    .param2 = @intCast(p),
                    .expected = expected,
                    .is_positive = true,
                    .equivalent_pair_id = null,
                });
            }
        }

        // 4. зЯЫзЫЊеЊЛпЉЪ¬ђ(PвИІ¬ђP) жБТдЄЇзЬЯ вЖТ BasicDeltaOperation
        {
            const booleans = [_]u64{ 0, 1 };
            for (booleans) |p| {
                const p_id = try engine.getOrCreateNumber(p);
                const not_p_val = engine.deltaExpr(engine.one_id, p_id);
                const not_p_id = try engine.getOrCreateNumber(@intFromFloat(not_p_val));
                const meet_p_notp = try engine.latticeMeet(p_id, not_p_id);
                const meet_p_notp_id = try engine.getOrCreateNumber(@intFromFloat(meet_p_notp));
                const result: f64 = engine.deltaExpr(engine.one_id, meet_p_notp_id);
                const expected: i64 = @intFromFloat(result);
                try self.adversarial_boundary.append(self.allocator, .{
                    .sample_type = .AdversarialBoundary,
                    .level = 3,
                    .complexity = .Level_1,
                    .param1 = @intCast(p),
                    .param2 = 0,
                    .expected = expected,
                    .is_positive = true,
                    .equivalent_pair_id = null,
                });
            }
        }
    }
};

// ============================================================
// еНХеЕГжµЛиѓХ
// ============================================================

test "LogicDataset еИЭеІЛеМЦ" {
    var dataset = LogicDataset.init(std.testing.allocator);
    defer dataset.deinit();

    try std.testing.expectEqual(@as(usize, 0), dataset.axiom_benchmarks.items.len);
    try std.testing.expectEqual(@as(usize, 0), dataset.bootstrap_generated.items.len);
    try std.testing.expectEqual(@as(usize, 0), dataset.auto_expanded.items.len);
    try std.testing.expectEqual(@as(usize, 0), dataset.adversarial_boundary.items.len);
}

test "LogicDataset еЕђзРЖеЯЇеЗЖйЫЖзФЯжИР" {
    var dataset = LogicDataset.init(std.testing.allocator);
    defer dataset.deinit();
    var engine = try DeltaEngine.init(std.testing.allocator);
    defer engine.deinit();

    try dataset.generateAxiomBenchmarks(&engine);

    // 4зІНP,QзїДеРИ √Ч 5дЄ™LatticeOperation(AND/OR/вЖТ/вЖФ/вКХ) = 20ж≠£+4иіЯ + 2дЄ™NOT
    try std.testing.expect(dataset.axiom_benchmarks.items.len >= 24);
    try std.testing.expect(dataset.sampleCount(.AxiomBenchmark) >= 24);

    for (dataset.axiom_benchmarks.items) |sample| {
        try std.testing.expect(sample.complexity == .Level_3 or
            sample.complexity == .Level_1);
    }
}

test "LogicDataset иЗ™дЄЊзФЯжИРйЫЖ" {
    var dataset = LogicDataset.init(std.testing.allocator);
    defer dataset.deinit();
    var engine = try DeltaEngine.init(std.testing.allocator);
    defer engine.deinit();

    try dataset.generateBootstrapSamples(&engine);

    try std.testing.expect(dataset.bootstrap_generated.items.len > 0);
    try std.testing.expect(dataset.sampleCount(.BootstrapGenerated) > 0);

    for (dataset.bootstrap_generated.items) |sample| {
        try std.testing.expect(sample.complexity == .Level_3);
    }
}

test "LogicDataset иЗ™дЄїжЙ©еЉ†йЫЖ" {
    var dataset = LogicDataset.init(std.testing.allocator);
    defer dataset.deinit();
    var engine = try DeltaEngine.init(std.testing.allocator);
    defer engine.deinit();

    try dataset.generateAutoExpandedSamples(&engine);

    try std.testing.expect(dataset.auto_expanded.items.len > 0);
    try std.testing.expect(dataset.sampleCount(.AutoExpanded) > 0);

    for (dataset.auto_expanded.items) |sample| {
        try std.testing.expect(sample.complexity == .Level_3);
    }
}

test "LogicDataset еѓєжКЧиЊєзХМйЫЖ" {
    var dataset = LogicDataset.init(std.testing.allocator);
    defer dataset.deinit();
    var engine = try DeltaEngine.init(std.testing.allocator);
    defer engine.deinit();

    try dataset.generateAdversarialSamples(&engine);

    try std.testing.expect(dataset.adversarial_boundary.items.len > 0);
    try std.testing.expect(dataset.sampleCount(.AdversarialBoundary) > 0);

    for (dataset.adversarial_boundary.items) |sample| {
        try std.testing.expect(sample.complexity == .Level_3 or
            sample.complexity == .Level_1);
    }
}

test "LogicDataset еЕ®йЗПзФЯжИРдЄОз±їеЮЛзЇ¶жЭЯй™МиѓБ" {
    var dataset = LogicDataset.init(std.testing.allocator);
    defer dataset.deinit();
    var engine = try DeltaEngine.init(std.testing.allocator);
    defer engine.deinit();

    try dataset.generateAxiomBenchmarks(&engine);
    try dataset.generateBootstrapSamples(&engine);
    try dataset.generateAutoExpandedSamples(&engine);
    try dataset.generateAdversarialSamples(&engine);

    try std.testing.expect(dataset.totalCount() > 50);

    // йБНеОЖжЙАжЬЙеЫЫе±Вж†ЈжЬђпЉМй™МиѓБжЧ†дїїдљХиЊЕеК©еЗљжХ∞еЉХеЕ•зЪДйҐЭе§Цз±їеЮЛ
    for (dataset.axiom_benchmarks.items) |s| {
        try std.testing.expect(s.complexity == .Level_3 or
            s.complexity == .Level_1);
    }
    for (dataset.bootstrap_generated.items) |s| {
        try std.testing.expect(s.complexity == .Level_3 or
            s.complexity == .Level_1);
    }
    for (dataset.auto_expanded.items) |s| {
        try std.testing.expect(s.complexity == .Level_3 or
            s.complexity == .Level_1);
    }
    for (dataset.adversarial_boundary.items) |s| {
        try std.testing.expect(s.complexity == .Level_3 or
            s.complexity == .Level_1);
    }
}

test "LogicDataset еЕђзРЖеЯЇеЗЖйЫЖйАїиЊСж≠£з°ЃжАІ" {
    var dataset = LogicDataset.init(std.testing.allocator);
    defer dataset.deinit();
    var engine = try DeltaEngine.init(std.testing.allocator);
    defer engine.deinit();

    try dataset.generateAxiomBenchmarks(&engine);

    // й™МиѓБжЙАжЬЙж≠£ж†ЈжЬђзЪДexpectedеАЉйБµеЊ™еЄГе∞ФеЯЯ{0,1}
    for (dataset.axiom_benchmarks.items) |sample| {
        if (sample.is_positive) {
            try std.testing.expect(sample.expected == 0 or sample.expected == 1);
        }
    }
}